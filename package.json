{
  "name": "leo-work",
  "private": true,
  "version": "0.1.8",
  "type": "module",
  "description": "Leo work — 本地隱私安全 + 跨會議記憶的桌面錄音/AI 助理（全本地、免費、離線；Tauri + React + Node sidecar）",
  "scripts": {
    "dev": "concurrently -k -n web,sidecar -c cyan,magenta \"npm:dev:web\" \"npm:dev:sidecar\"",
    "dev:web": "vite",
    "dev:sidecar": "tsx watch src/server.ts",
    "build:web": "vite build",
    "build:sidecar": "esbuild src/server.ts --bundle --platform=node --format=cjs --outfile=dist-sidecar/server.cjs --external:@lancedb/lancedb --external:@xenova/transformers --external:ffmpeg-static",
    "assemble:sidecar": "node scripts/assemble-sidecar.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.sidecar.json",
    "build": "npm run typecheck && npm run build:web",
    "build:release": "npm run build && npm run assemble:sidecar",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@lancedb/lancedb": "^0.13.0",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "docx": "^9.7.1",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "openai": "^4.77.0",
    "opus-decoder": "^0.7.11",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "selfsigned": "^2.4.1",
    "werift": "^0.23.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
