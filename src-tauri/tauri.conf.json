{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Leo work",
  "version": "0.1.2",
  "identifier": "com.leowork.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:release"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Leo work",
        "width": 1280,
        "height": 820,
        "minWidth": 1000,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8765 http://localhost:8765; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "nsis", "app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": ["binaries/leo-node"],
    "resources": ["sidecar/**/*"]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/leohsieh0907-del/leo-work/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0RjlEOEVEOTY3OEUxQgpSV1Fiam1mWmpwMVBEdlJwTzdBcUFtbzJzZ1ErZVVrbW9zeHhVQ2oyNTNreVl2dXhZY0VPVDgyeAo="
    }
  }
}
