# ── Leo work 環境變數範例 ──
# 複製為 .env 後填入；.env 已被 .gitignore 排除（金鑰不進版控）。

# ── LLM 來源（摘要 / 分析 / 翻譯）──
# 預設 ollama＝完全免費、離線、$0，無需任何金鑰。
LLM_PROVIDER=ollama
# 本地 Ollama 模型（無 GPU 建議 qwen2.5:3b；硬體夠可換 qwen2.5:7b）
# 安裝：https://ollama.com  →  ollama pull qwen2.5:3b
OLLAMA_LLM_MODEL=qwen2.5:3b

# ── （選配）Claude API ──
# 只有把 LLM_PROVIDER 改成 claude 才需要；用 API 逐 token 收費（Claude Max 訂閱不涵蓋）。
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── 本地向量資料庫 ──
# LanceDB 資料夾路徑（嵌入式，落地檔案）
LOCAL_DB_PATH=./data/lancedb

# 嵌入模型來源：local（ONNX all-MiniLM-L6-v2，預設、不聯網）| openai | ollama
EMBEDDING_PROVIDER=local
# 切到 openai 時需要（embedding 用）
OPENAI_API_KEY=
# 切到 ollama 時的服務位址與模型
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── 階段一：加密 ──
# 金鑰推導用的 salt（請改成你自己的隨機長字串；變更後舊檔將無法解密）
ENCRYPTION_SALT=change-me-to-a-long-random-string

# ── Sidecar 服務埠 ──
SIDECAR_PORT=8765

# ── 雙源收音 ──
# 手機橋接 WSS 埠（self-signed HTTPS；手機掃 QR 連這個埠）
PHONE_BRIDGE_PORT=8443
# 本地 Whisper.cpp 執行檔與模型（手機/系統收音即時轉寫用；未設定則不轉寫）
# WHISPER_BIN=C:\tools\whisper\whisper-cli.exe
# WHISPER_MODEL_PATH=./models/ggml-base.bin
